{
    "name": "carliban/laravel-table-permissions",
    "description": "Generador automático de roles y permisos para Laravel usando Spatie Permission",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/view": "^12.0",
        "spatie/laravel-permission": "^6.0"
    },

    "homepage": "https://github.com/igCarlos/TablePermissions",
    "authors": [
        {
            "name": "Carlos Ivan",
            "homepage": "https://github.com/igCarlos",
            "role": "Developer"
        }
    ],

    "autoload": {
        "psr-4": {
            "Carliban\\TablePermissions\\": "src/"
        }
    },

    "extra": {
        "laravel": {
            "providers": [
                "Carliban\\TablePermissions\\TablePermissionsServiceProvider"
            ]
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true
}